{
    "version": 2,
    "builds": [
      {
        "src": "index.js",
        "use": "@vercel/node",
        "config": { "zeroConfig": true }
      }
    ],
      "hooks": {
    "build": "npx prisma generate"
  },
    "routes": [
      {
        "src": "/api/.*",
        "dest": "index.js"
      },
      {
        "src": "/(.*)",
        "dest": "/index.html"
      }
    ]
  }