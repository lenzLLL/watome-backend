// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client-js"
}

// datasource db {
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // uses connection pooling
}

model User {
  id                  String              @id @default(uuid())
  categoryAccount     EnumCategoryAccount @default(CUSTOMER)
  firstname           String
  phone               String?             @unique
  desc                String?
  agence              String?
  lastname            String
  email               String              @unique
  password            String
  address             String?
  city                String?
  country             String?
  profilePicture      String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  isActive            Boolean             @default(false)
  activationToken     String?             @unique
  passwordResetToken  String?             @unique
  passwordResetExpiry DateTime?

  // Agent-specific fields
  languages           String[]            @default([])
  experience          String?
  salesCount          Int                 @default(0)
  specialties         String[]            @default([])
  bio                 String?

  planSubscriptionId  String?
  subscription        PlanSubscription?   @relation(fields: [planSubscriptionId], references: [id], onDelete: SetNull)
  properties          Property[]
  missionsRequested   Mission[]           @relation("UserMissions")
  missionsAssigned    Mission[]           @relation("AgentMissions")
  bookings            Booking[]
  favorites           Favorite[]
  subscriptionHistory SubscriptionHistory[]

  // Reviews written by this user as customer
  reviews             AgentReview[]        @relation("UserReviews")
  // Reviews received as agent
  agentReviews        AgentReview[]        @relation("AgentReviews")
}

enum EnumCategoryAccount {
  AGENT
  AGENCE
  ADMIN
  CUSTOMER
}

model PlanSubscription {
  id                     String   @id @default(uuid())
  name                   String
  price                  Float
  monthDuration          Int
  infos                  String[]
  visiblePropertiesLimit Int      @default(5)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  users                  User[]
  subscriptions          UserSubscription[]
  subscriptionHistory    SubscriptionHistory[]
}

model UserSubscription {
  id                String         @id @default(uuid())
  userId            String         @unique
  planId            String
  startDate         DateTime       @default(now())
  endDate           DateTime
  paymentMethod     String?
  amount            Float
  status            String         @default("ACTIVE")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  plan              PlanSubscription @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
}

model SubscriptionHistory {
  id                String         @id @default(uuid())
  userId            String
  planId            String
  action            SubscriptionAction
  amount            Float
  paymentMethod     String?
  paymentStatus     PaymentStatus  @default(PENDING)
  transactionId     String?
  startDate         DateTime
  endDate           DateTime
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              PlanSubscription @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
  @@index([createdAt])
}

enum SubscriptionAction {
  SUBSCRIBE
  RENEW
  UPGRADE
  DOWNGRADE
  CANCEL
  EXPIRE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Property {
  id                String            @id @default(uuid())
  title             String
  description       String
  price             Float
  type              EnumTypeProperty
  category          EnumApartmentType
  isSale            Boolean           @default(false)
  isVisible         Boolean           @default(true)
  location          String
  images            String[]
  address           String
  longitude         Float
  latitude          Float
  chambres          Int
  sallesDeBain      Int
  salon             Int
  surface           Float
  isWifi            Boolean           @default(false)
  isParking         Boolean           @default(false)
  isClimatisation   Boolean           @default(false)
  isPiscine         Boolean           @default(false)
  isGarden          Boolean           @default(false)
  isAscenseur       Boolean           @default(false)
  isAnimauxAcceptes Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  userId   String
  views    BigInt       @default(0)
  desc     String?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  favorites Favorite[]

  @@index([price])
  @@index([location])
  @@index([longitude, latitude])
}

model Booking {
  id         String        @id @default(uuid())
  startDate  DateTime
  endDate    DateTime?
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  price      Decimal       @db.Decimal(10, 2)
  customerId String
  propertyId String
  customer   User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Reviews associated with this booking
  reviews    AgentReview[]

  @@index([customerId, propertyId])
}

enum EnumTypeProperty {
  RENT
  SALE
}

enum EnumApartmentType {
  APPARTEMENT
  VILLA
  MAISON
  CHAMBRE
  TERRAIN
  DUPLEX
  MEUBLE
}

model Mission {
  id            String            @id @default(uuid())
  userId        String?
  user          User?              @relation("UserMissions", fields: [userId], references: [id], onDelete: Cascade)
  agentId       String?
  agent         User?             @relation("AgentMissions", fields: [agentId], references: [id], onDelete: Cascade)
  // when an agent accepts the mission
  agentMessage  String?
  acceptedAt    DateTime?
  // location details – address plus optional city/country for filtering and display
  address       String
  city          String
  country       String
  // customer contact info (required if not logged in)
  customerEmail String?
  customerPhone String?
  customerName  String?
  minPrice      Float
  maxPrice      Float
  apartmentType EnumApartmentType
  description   String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId])
  @@index([agentId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model AgentReview {
  id          String   @id @default(uuid())
  reviewerId  String
  agentId     String
  bookingId   String?
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviewer    User     @relation("UserReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  agent       User     @relation("AgentReviews", fields: [agentId], references: [id], onDelete: Cascade)
  booking     Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([reviewerId])
  @@index([bookingId])
  @@unique([reviewerId, agentId])
}

